flowchart TD
  %% DCIM Core Platform - Data Flow Architecture

  subgraph COLLECT["Collection Layer"]
    TELEGRAF["Telegraf Collectors<br/>SNMP Redfish Exec Metrics"]
    NIFI_SRC["NiFi Connectors<br/>REST Modbus JDBC SFTP MQTT"]
    WAZUH["Wazuh Filebeat Syslog<br/>Security and Log Events"]
    BATCH["Manual API and Batch Import<br/>CSV JSON ERP ITSM DMS"]
  end

  subgraph KAFKA["Kafka Event Backbone HA"]
    RAW["dcim.events.raw<br/>Raw events"]
    VALIDATED["dcim.events.validated<br/>Validated events"]
    ENRICHED["dcim.events.enriched<br/>Context enriched events"]
    DLQ["dcim.events.dlq<br/>Dead letter queue"]
    CMDB_T["dcim.cmdb.updates"]
    ASSET_T["dcim.asset.updates"]
    SIEM_T["dcim.siem.events"]
    ANALYTICS_T["dcim.analytics.metrics"]
    WORKFLOW_T["dcim.workflow.events"]
    LINEAGE_T["dcim.lineage.events"]
  end

  SCHEMA["Schema Registry<br/>Backward compatible schemas"]

  subgraph PROCESS["Processing and Governance"]
    VALIDATOR["Validation and Normalization<br/>Schema Type Range Format Duplicate Freshness"]
    ENRICHER["NiFi Enrichment Processor"]
    ENRICH_API["Enrichment API<br/>CMDB Asset Location Priority Impact"]
    REDIS["Redis Cache<br/>Low latency lookup"]
    ROUTER["Event Router<br/>Route by event type priority category"]
    LINEAGE["Lineage Tracker<br/>source raw validation enrichment routing store"]
    DLQ_CONS["DLQ Consumer<br/>Retry Archive Alert"]
  end

  subgraph CONSUMERS["Downstream Consumers"]
    CMDB_CONS["CMDB Consumer<br/>upsert CI relationships"]
    ASSET_CONS["Asset Consumer<br/>asset lifecycle reconciliation"]
    SIEM_CONS["SIEM Consumer<br/>Wazuh ES SOC alerts"]
    ANA_CONS["Analytics Consumer<br/>TimescaleDB AI scoring"]
    WF_CONS["Workflow Consumer<br/>n8n Temporal trigger"]
    LIN_CONS["Lineage Writer<br/>audit and trace store"]
  end

  subgraph STORES["Stores and Action Systems"]
    CMDB["CMDB or iTop"]
    AR["Asset Repository or Ralph"]
    TSDB["TimescaleDB or InfluxDB"]
    ES["Elasticsearch or OpenSearch"]
    WF["Workflow Automation"]
    AUDIT["PostgreSQL Lineage Audit"]
    ARCHIVE["S3 MinIO Archive"]
    ALERT["Prometheus Alertmanager<br/>Telegram Email ChatOps"]
  end

  TELEGRAF --> RAW
  NIFI_SRC --> RAW
  WAZUH --> SIEM_T
  BATCH --> RAW

  SCHEMA -. validates .-> VALIDATOR
  RAW --> VALIDATOR
  VALIDATOR -- pass --> VALIDATED
  VALIDATOR -- reject --> DLQ

  VALIDATED --> ENRICHER
  ENRICHER --> ENRICH_API
  ENRICH_API <--> REDIS
  ENRICH_API <--> CMDB
  ENRICH_API <--> AR
  ENRICHER -- pass --> ENRICHED
  ENRICHER -- fail or partial --> DLQ

  ENRICHED --> ROUTER
  ROUTER --> CMDB_T
  ROUTER --> ASSET_T
  ROUTER --> SIEM_T
  ROUTER --> ANALYTICS_T
  ROUTER --> WORKFLOW_T
  ROUTER --> LINEAGE_T

  CMDB_T --> CMDB_CONS --> CMDB
  ASSET_T --> ASSET_CONS --> AR
  SIEM_T --> SIEM_CONS --> ES
  ANALYTICS_T --> ANA_CONS --> TSDB
  WORKFLOW_T --> WF_CONS --> WF
  LINEAGE_T --> LIN_CONS --> AUDIT

  DLQ --> DLQ_CONS
  DLQ_CONS -- transient retry --> RAW
  DLQ_CONS -- permanent archive --> ARCHIVE
  DLQ_CONS -- threshold breach --> ALERT

  VALIDATOR -. lineage .-> LINEAGE
  ENRICHER -. lineage .-> LINEAGE
  ROUTER -. lineage .-> LINEAGE
  CMDB_CONS -. lineage .-> LINEAGE
  ASSET_CONS -. lineage .-> LINEAGE
  SIEM_CONS -. lineage .-> LINEAGE
  ANA_CONS -. lineage .-> LINEAGE
  WF_CONS -. lineage .-> LINEAGE
  LINEAGE --> LINEAGE_T

  TSDB --> ALERT
  ES --> ALERT
  WF --> ALERT

  classDef collect fill:#e8f4ff,stroke:#2b6cb0,color:#0b1f33,stroke-width:1px
  classDef topic fill:#fef3c7,stroke:#d97706,color:#422006,stroke-width:1.3px
  classDef processor fill:#eef2ff,stroke:#4f46e5,color:#111827,stroke-width:1.5px
  classDef store fill:#ecfdf5,stroke:#059669,color:#06281d,stroke-width:1.3px
  classDef error fill:#fef2f2,stroke:#dc2626,color:#450a0a,stroke-width:1.5px
  classDef control fill:#f5f3ff,stroke:#7c3aed,color:#1e1b4b,stroke-width:1px

  class TELEGRAF,NIFI_SRC,WAZUH,BATCH collect
  class RAW,VALIDATED,ENRICHED,CMDB_T,ASSET_T,SIEM_T,ANALYTICS_T,WORKFLOW_T,LINEAGE_T topic
  class VALIDATOR,ENRICHER,ENRICH_API,ROUTER,LINEAGE,CMDB_CONS,ASSET_CONS,SIEM_CONS,ANA_CONS,WF_CONS,LIN_CONS processor
  class CMDB,AR,TSDB,ES,WF,AUDIT,ARCHIVE store
  class DLQ,DLQ_CONS error
  class SCHEMA,REDIS,ALERT control